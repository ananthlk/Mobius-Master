# mobius-feedback — Cloud Run dev config.

GCP_PROJECT=mobius-os-dev
GCP_REGION=us-central1

SERVICE_NAME=mobius-feedback
SERVICE_ACCOUNT=mobius-platform-dev@mobius-os-dev.iam.gserviceaccount.com
AR_REPO=mobius-feedback
IMAGE_BASE=us-central1-docker.pkg.dev/mobius-os-dev/mobius-feedback/feedback

# Routes to chat LLM router (cheap+fast tier via the "feedback_classify" stage).
FEEDBACK_LLM_STAGE=feedback_classify
FEEDBACK_MAX_TOKENS=600

# Chat LLM router (POST {URL}/internal/skill-llm). Service appends path itself.
FEEDBACK_LLM_ROUTER_URL=https://mobius-chat-ortabkknqa-uc.a.run.app

# Tiny — single endpoint, stateless, low traffic.
RUN_MEMORY=512Mi
RUN_CPU=1
RUN_CONCURRENCY=40
RUN_TIMEOUT=30
RUN_MIN_INSTANCES=0
RUN_MAX_INSTANCES=3
