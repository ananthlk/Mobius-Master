#!/usr/bin/env bash
# Start all Mobius backends, frontends, and workers using shared venv.
# Usage: mstart [--no-rag-frontend] [--no-os-extension] [--no-landing] [--skip-migrations]

set -e
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" == /* ]] && SCRIPT="$TARGET" || SCRIPT="$(dirname "$SCRIPT")/$TARGET"
done
# pwd -P: canonical path (helps when $0 resolves with different casing than the real directory).
MOBIUS_ROOT="$(cd "$(dirname "$SCRIPT")" && pwd -P 2>/dev/null || pwd)"
cd "$MOBIUS_ROOT" || exit 1

PIDFILE="$MOBIUS_ROOT/.mobius_start_all.pids"
LOGDIR="$MOBIUS_ROOT/.mobius_logs"
VENV="$MOBIUS_ROOT/.venv"
mkdir -p "$LOGDIR"

# Check for shared venv
if [[ ! -d "$VENV" ]]; then
  echo "[mstart] ERROR: Shared venv not found at $VENV"
  echo "  Create it: cd $MOBIUS_ROOT && python3.11 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt"
  exit 1
fi

START_RAG_FRONTEND=true
START_OS_EXTENSION=true
START_LANDING=true
RESTART_CLOUDSQL=false
SKIP_MIGRATIONS=false
for arg in "$@"; do
  case "$arg" in
    --no-rag-frontend) START_RAG_FRONTEND=false ;;
    --no-os-extension) START_OS_EXTENSION=false ;;
    --no-landing) START_LANDING=false ;;
    --restart-db) RESTART_CLOUDSQL=true ;;
    --skip-migrations) SKIP_MIGRATIONS=true ;;
  esac
done

# When --no-landing, preserve mobius-landing PIDs (don't kill, keep in file at end)
LANDING_LINES=""
if [[ "$START_LANDING" == "false" ]] && [[ -f "$PIDFILE" ]]; then
  while read -r pid name; do
    [[ -z "$pid" ]] || [[ ! "$name" ]] && continue
    if [[ "$name" == "mobius-landing" ]]; then
      LANDING_LINES="${LANDING_LINES}${pid} ${name}"$'\n'
    fi
  done < "$PIDFILE"
fi

# --- Kill existing servers first ---
if [[ -f "$PIDFILE" ]]; then
  echo "[mstart] Stopping existing Mobius processes ..."
  while read -r pid name; do
    [[ -z "$pid" ]] && continue
    if [[ "$START_LANDING" == "false" ]] && [[ "$name" == "mobius-landing" ]]; then
      continue
    fi
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      echo "  Stopped $name (PID $pid)"
    fi
  done < "$PIDFILE"
  if [[ "$START_LANDING" == "true" ]]; then
    rm -f "$PIDFILE"
  fi
  echo "[mstart] Waiting for processes to exit (DB connections to close) ..."
  sleep 8
fi

: > "$PIDFILE"

_log() { echo "[mstart] $*"; }

# Terminate idle sessions on mobius_* DBs to free Cloud SQL connection slots before migrations.
_cleanup_db_connections() {
  if [[ ! -x "$VENV/bin/python3" ]] || [[ ! -f "$MOBIUS_ROOT/scripts/cleanup_db_connections.py" ]]; then
    return 0
  fi
  _log "Cleaning up idle DB connections (mobius_chat / mobius_rag / mobius_qa) …"
  if "$VENV/bin/python3" "$MOBIUS_ROOT/scripts/cleanup_db_connections.py" >> "$LOGDIR/cleanup_db_connections.log" 2>&1; then
    _log "  Idle connection cleanup OK (log: $LOGDIR/cleanup_db_connections.log)"
  else
    _log "  Idle connection cleanup failed or could not connect — see $LOGDIR/cleanup_db_connections.log"
    _log "  Waiting 5s and retrying cleanup once (remote clients may still be releasing slots) …"
    sleep 5
    if "$VENV/bin/python3" "$MOBIUS_ROOT/scripts/cleanup_db_connections.py" >> "$LOGDIR/cleanup_db_connections.log" 2>&1; then
      _log "  Second cleanup attempt OK"
    else
      _log "  Second cleanup failed — DB may have zero free slots. Fix: stop other consumers, then mstart --restart-db (Cloud SQL restart)"
      _log "  Tip: CHAT_RAG_DATABASE_ADMIN_URL in mobius-chat/.env (postgres user, .../postgres) if not set."
    fi
  fi
}

# Kill any process bound to port so services can bind to fixed ports.
_kill_port() {
  local port=$1
  local pids
  pids=$(lsof -ti :"$port" 2>/dev/null) || true
  if [[ -n "$pids" ]]; then
    _log "Freeing port $port (killing existing process)"
    echo "$pids" | xargs kill -9 2>/dev/null || true
    sleep 2
  fi
}

_start() {
  local name="$1"
  local cmd="$2"
  _log "Starting $name ..."
  eval "$cmd" >> "$LOGDIR/${name}.log" 2>&1 &
  local pid=$!
  echo "$pid $name" >> "$PIDFILE"
  _log "  PID $pid"
}

# Wait for Redis at REDIS_URL (used after starting tunnel). Up to 15s.
_wait_redis() {
  sleep 2
  if [[ ! -x "$VENV/bin/python3" ]]; then return; fi
  local i
  for (( i=0; i<15; i++ )); do
    if ( cd "$MOBIUS_ROOT/mobius-skills/web-scraper" 2>/dev/null && "$VENV/bin/python3" -c "
import sys; sys.path.insert(0, '.'); from app.config import REDIS_URL
import redis; redis.from_url(REDIS_URL, socket_connect_timeout=2).ping()
" 2>/dev/null ); then
      _log "  Redis reachable"
      return
    fi
    sleep 1
  done
  _log "  Redis not reachable yet (tunnel may still be connecting)"
}

# Wait for Redis at REDIS_URL (from current env). Up to 30s. Used before mobius-chat worker.
_wait_redis_for_chat() {
  local url="${REDIS_URL:-}"
  [[ -z "$url" ]] && return
  if [[ ! -x "$VENV/bin/python3" ]]; then return; fi
  local i
  for (( i=0; i<30; i++ )); do
    if "$VENV/bin/python3" -c "
import os
import redis
url = os.environ.get('REDIS_URL', '')
if url:
    redis.from_url(url, decode_responses=True, socket_connect_timeout=3).ping()
" 2>/dev/null; then
      _log "  Redis reachable for chat worker"
      return
    fi
    sleep 1
  done
  _log "  Redis not reachable (chat worker will retry on startup)"
}

# Load .env files for services that need env vars
_load_env() {
  local envfile="$1"
  if [[ -f "$envfile" ]]; then
    while IFS= read -r _mline || [[ -n "$_mline" ]]; do
      [[ -z "$_mline" || "$_mline" =~ ^[[:space:]]*# ]] && continue
      if [[ "$_mline" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
        # Export literally (avoid shell expansion of $... sequences in values).
        local k="${BASH_REMATCH[1]}"
        local v="${BASH_REMATCH[2]}"
        printf -v "$k" '%s' "$v"
        export "$k"
      fi
    done < "$envfile"
  fi
}

# Derive Postgres user/pass/host/port from a URL (best-effort).
_pg_user_from_url() {
  local url="$1"
  if [[ "$url" =~ ^postgresql(\+asyncpg)?://([^:/]+):([^@]+)@ ]]; then
    printf "%s" "${BASH_REMATCH[2]}"
  fi
}
_pg_pass_from_url() {
  local url="$1"
  if [[ "$url" =~ ^postgresql(\+asyncpg)?://([^:/]+):([^@]+)@ ]]; then
    printf "%s" "${BASH_REMATCH[3]}"
  fi
}
_pg_host_from_url() {
  local url="$1"
  if [[ "$url" =~ @([^:/]+)(:[0-9]+)?/ ]]; then
    printf "%s" "${BASH_REMATCH[1]}"
  else
    printf "%s" "${POSTGRES_HOST:-34.135.72.145}"
  fi
}
_pg_port_from_url() {
  local url="$1"
  if [[ "$url" =~ @[^:]+:([0-9]+)/ ]]; then
    printf "%s" "${BASH_REMATCH[1]}"
  else
    printf "%s" "${POSTGRES_PORT:-5432}"
  fi
}

# --- Restart Cloud SQL to clear connections (optional, for "connection slots" errors) ---
if [[ "$RESTART_CLOUDSQL" == "true" ]]; then
  _log "Restarting Cloud SQL instance (clears all connections) ..."
  CLOUDSQL_INST="${CLOUDSQL_INSTANCE:-mobius-platform-dev-db}"
  CLOUDSQL_PROJ="${GCP_PROJECT:-mobius-os-dev}"
  if command -v gcloud >/dev/null 2>&1; then
    gcloud sql instances restart "$CLOUDSQL_INST" --project="$CLOUDSQL_PROJ" --quiet 2>/dev/null && _log "  Instance restarted. Waiting 35s ..." && sleep 35 || _log "  Restart failed or skipped"
  else
    _log "  gcloud not found; skip --restart-db"
  fi
fi

# --- Cloud SQL Proxy (ensure DB reachable before migrations) ---
_load_env "$MOBIUS_ROOT/mobius-chat/.env" 2>/dev/null || true
CHAT_DB_URL="${CHAT_RAG_DATABASE_URL:-}"
CLOUDSQL_CONN="${CLOUDSQL_CONNECTION_NAME:-mobius-os-dev:us-central1:mobius-platform-dev-db}"
PROXY_PORT=5433
NEED_PROXY=false
if [[ "$CHAT_DB_URL" =~ 127\.0\.0\.1:$PROXY_PORT ]] || [[ "$CHAT_DB_URL" =~ 34\.135\.72\.145 ]]; then
  NEED_PROXY=true
fi
if [[ "$NEED_PROXY" == "true" ]]; then
  PROXY_BIN=""
  for p in cloud-sql-proxy "$HOME/google-cloud-sdk/bin/cloud-sql-proxy" /opt/homebrew/bin/cloud-sql-proxy; do
    if command -v "$p" >/dev/null 2>&1 || [[ -x "$p" ]] 2>/dev/null; then
      PROXY_BIN="$p"
      break
    fi
  done
  if [[ -n "$PROXY_BIN" ]]; then
    # Restart proxy before migrations to clear connection slots (stale connections from stopped services)
    if nc -z 127.0.0.1 "$PROXY_PORT" 2>/dev/null; then
      _log "Restarting Cloud SQL Proxy (clears connection slots) ..."
      _kill_port "$PROXY_PORT"
      sleep 8
    fi
    if ! nc -z 127.0.0.1 "$PROXY_PORT" 2>/dev/null; then
      _log "Starting Cloud SQL Proxy (port $PROXY_PORT) ..."
      "$PROXY_BIN" "$CLOUDSQL_CONN" --port "$PROXY_PORT" >> "$LOGDIR/cloud-sql-proxy.log" 2>&1 &
      for (( _i=0; _i<15; _i++ )); do
        if nc -z 127.0.0.1 "$PROXY_PORT" 2>/dev/null; then
          _log "  Cloud SQL Proxy ready"
          break
        fi
        sleep 1
      done
    fi
    # Use 127.0.0.1:5433 for migrations when .env pointed to Cloud SQL
    if [[ "$CHAT_DB_URL" =~ 34\.135\.72\.145 ]]; then
      export CHAT_RAG_DATABASE_URL="${CHAT_DB_URL/34.135.72.145:5432/127.0.0.1:$PROXY_PORT}"
    fi
  fi
fi

# --- mobius-chat DB migrations (run before starting chat services) ---
if [[ "$SKIP_MIGRATIONS" == "true" ]]; then
  _log "Skipping DB migrations (--skip-migrations)"
elif [[ -d "$MOBIUS_ROOT/mobius-chat" ]]; then
  _log "Running mobius-chat DB migrations ..."
  sleep 3
  _load_env "$MOBIUS_ROOT/mobius-chat/.env"
  CHAT_DB_URL="${CHAT_RAG_DATABASE_URL:-$CHAT_DB_URL}"
  if [[ "$NEED_PROXY" == "true" ]] && [[ "$CHAT_DB_URL" =~ 34\.135\.72\.145 ]]; then
    export CHAT_RAG_DATABASE_URL="${CHAT_DB_URL/34.135.72.145:5432/127.0.0.1:$PROXY_PORT}"
  fi
  # Same proxy rewrite for superuser cleanup URL when .env still points at Cloud SQL IP.
  if [[ "$NEED_PROXY" == "true" ]] && [[ -n "${CHAT_RAG_DATABASE_ADMIN_URL:-}" ]]; then
    if [[ "$CHAT_RAG_DATABASE_ADMIN_URL" =~ 34\.135\.72\.145 ]]; then
      export CHAT_RAG_DATABASE_ADMIN_URL="${CHAT_RAG_DATABASE_ADMIN_URL/34.135.72.145:5432/127.0.0.1:$PROXY_PORT}"
    fi
  fi
  if [[ -n "${CHAT_RAG_DATABASE_ADMIN_URL:-}" ]]; then
    _log "CHAT_RAG_DATABASE_ADMIN_URL is set (superuser cleanup / migrations will use it)"
  fi
  _cleanup_db_connections
  _migrations_ok=false
  for _attempt in 1 2 3 4; do
    if [[ $_attempt -gt 1 ]]; then
      _log "Re-running idle connection cleanup before migration retry $_attempt …"
      _cleanup_db_connections
      sleep 2
    fi
    if (cd "$MOBIUS_ROOT/mobius-chat" && "$VENV/bin/python3" -m app.db.run_migrations 2>&1); then
      _migrations_ok=true
      _log "Migrations OK"
      break
    fi
    if [[ $_attempt -lt 4 ]]; then
      _log "Migrations failed (attempt $_attempt), retrying in 30s ..."
      sleep 30
    fi
  done
  if [[ "$_migrations_ok" != "true" ]]; then
    _log "Migrations failed (check CHAT_RAG_DATABASE_URL). Services will start anyway."
    _log "  Connection slots exhausted? Stop other DB clients, then: mstart --restart-db  (restarts Cloud SQL)"
    _log "  Or: mstart --skip-migrations  and run migrations later when slots are free."
  fi

  # --- provider-roster-credentialing DB migrations (same DB as chat when CREDENTIALING_REPORT_DB_URL unset) ---
  if [[ "$_migrations_ok" == "true" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills/provider-roster-credentialing" ]]; then
    CRED_URL="${CREDENTIALING_REPORT_DB_URL:-$CHAT_RAG_DATABASE_URL}"
    if [[ -n "$CRED_URL" ]] && [[ -x "$VENV/bin/python3" ]] && [[ -f "$MOBIUS_ROOT/mobius-skills/provider-roster-credentialing/scripts/run_migrations.py" ]]; then
      _log "Running provider-roster-credentialing DB migrations ..."
      export CREDENTIALING_REPORT_DB_URL="${CREDENTIALING_REPORT_DB_URL:-$CHAT_RAG_DATABASE_URL}"
      if (cd "$MOBIUS_ROOT/mobius-skills/provider-roster-credentialing" && "$VENV/bin/python3" scripts/run_migrations.py 2>&1); then
        _log "  Credentialing migrations OK"
      else
        _log "  Credentialing migrations failed (non-fatal)"
      fi
    fi
  fi
fi

# --- mobius-os backend (port 5001) ---
if [[ -d "$MOBIUS_ROOT/mobius-os/backend" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-os/backend/.env"
  _start "mobius-os-backend" "cd $MOBIUS_ROOT/mobius-os/backend && $VENV/bin/python server.py"
fi

# --- mobius-os extension (webpack watch) ---
if [[ "$START_OS_EXTENSION" == "true" ]] && [[ -d "$MOBIUS_ROOT/mobius-os/extension" ]]; then
  if command -v npm >/dev/null 2>&1; then
    _start "mobius-os-extension" "cd $MOBIUS_ROOT/mobius-os/extension && npm run dev"
  else
    _log "Skip mobius-os extension (npm not found)"
  fi
fi

# --- Redis: start tunnel if REDIS_URL is localhost:6380 (IAP/SSH tunnel to cloud Redis) ---
_load_env "$MOBIUS_ROOT/mobius-skills/web-scraper/.env"
if [[ -f "$MOBIUS_ROOT/mobius-config/.env" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-config/.env"
fi

# PostgreSQL: All services connect directly to Cloud SQL (no local proxy).
# QA_DATABASE_URL and RAG_DATABASE_URL are derived from DATABASE_URL/CHAT_RAG_DATABASE_URL
# using the same host (e.g. 34.135.72.145). Set in mobius-config/.env or per-module .env.

REDIS_URL="${REDIS_URL:-}"
if [[ "$REDIS_URL" == *"127.0.0.1:6380"* ]] || [[ "$REDIS_URL" == *"localhost:6380"* ]]; then
  _log "Redis tunnel target (127.0.0.1:6380) detected; starting tunnel if configured ..."
  _kill_port 6380
  if [[ -n "${REDIS_TUNNEL_CMD:-}" ]]; then
    _start "mobius-redis-tunnel" "$REDIS_TUNNEL_CMD"
    _wait_redis
  elif [[ -n "${REDIS_TUNNEL_JUMP_INSTANCE:-}" ]]; then
    REDIS_TUNNEL_JUMP_ZONE="${REDIS_TUNNEL_JUMP_ZONE:-us-central1-a}"
    _start "mobius-redis-tunnel" "gcloud compute ssh $REDIS_TUNNEL_JUMP_INSTANCE --zone=$REDIS_TUNNEL_JUMP_ZONE -- -L 6380:10.40.102.67:6379 -N -o ServerAliveInterval=60 -o ServerAliveCountMax=3"
    _wait_redis
  else
    _log "  Set REDIS_TUNNEL_CMD or REDIS_TUNNEL_JUMP_INSTANCE (and optional REDIS_TUNNEL_JUMP_ZONE) in mobius-config/.env or web-scraper/.env to start the tunnel automatically."
    _log "  Or use local Redis: REDIS_URL=redis://localhost:6379/0 and run: brew services start redis"
  fi
fi
_log "Note: Redis at ${REDIS_URL:-redis://10.40.102.67:6379/0}"

# Kill phantom mobius-chat workers (not in PIDFILE); avoid matching mobius-rag app.worker
pkill -f "${MOBIUS_ROOT}/mobius-chat.*-m app\.worker" 2>/dev/null || true
pkill -f "cd ${MOBIUS_ROOT}/mobius-chat.*app\.worker" 2>/dev/null || true
sleep 1
REDIS_REQUEST_KEY="${REDIS_REQUEST_KEY:-mobius:chat:requests}"
if [[ -n "${REDIS_URL:-}" ]] && command -v redis-cli >/dev/null 2>&1; then
  if redis-cli -u "$REDIS_URL" DEL "$REDIS_REQUEST_KEY" >/dev/null 2>&1; then
    _log "Flushed Redis key $REDIS_REQUEST_KEY (chat request queue)"
  else
    _log "Redis queue flush skipped (redis-cli DEL failed or key missing)"
  fi
else
  _log "Redis queue flush skipped (REDIS_URL or redis-cli unset)"
fi
_log "[mstart] Phantom workers cleared"

# --- mobius-chat frontend build (ensures app.js is up to date) ---
if [[ -d "$MOBIUS_ROOT/mobius-chat/frontend" ]] && [[ -f "$MOBIUS_ROOT/mobius-chat/frontend/package.json" ]]; then
  if command -v npm >/dev/null 2>&1; then
    _log "Building mobius-chat frontend ..."
    (cd "$MOBIUS_ROOT/mobius-chat/frontend" && npm run build 2>&1) || _log "  Frontend build failed (run: cd mobius-chat/frontend && npm run build)"
  fi
fi

# --- mobius-chat API (port 8000) ---
if [[ -d "$MOBIUS_ROOT/mobius-chat" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-skills/web-scraper/.env"
  [[ -f "$MOBIUS_ROOT/mobius-config/.env" ]] && _load_env "$MOBIUS_ROOT/mobius-config/.env"
  _load_env "$MOBIUS_ROOT/mobius-chat/.env"
  # ReAct pipeline for chat API+worker — force on so MOBIUS_USE_REACT=0 in .env cannot disable it under mstart.
  export MOBIUS_USE_REACT=1
  export QUEUE_TYPE="${QUEUE_TYPE:-redis}"
  # Enable skills when services are started (override .env if not set)
  [[ -z "${CHAT_SKILLS_GOOGLE_SEARCH_URL:-}" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills/google-search" ]] && export CHAT_SKILLS_GOOGLE_SEARCH_URL="http://localhost:8004/search?"
  [[ -z "${CHAT_SKILLS_WEB_SCRAPER_URL:-}" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills/web-scraper" ]] && export CHAT_SKILLS_WEB_SCRAPER_URL="http://localhost:8002/scrape/review"
  [[ -z "${CHAT_SKILLS_PROVIDER_ROSTER_CREDENTIALING_URL:-}" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills/provider-roster-credentialing" ]] && export CHAT_SKILLS_PROVIDER_ROSTER_CREDENTIALING_URL="http://localhost:8011/report"
  # MCP: tool agent calls skills via MCP (mobius-skills-mcp on port 8006)
  [[ -z "${MCP_SERVER_URL:-}" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills-mcp" ]] && export MCP_SERVER_URL="http://localhost:8006/mcp"
  # Shared secret for credentialing skill → chat POST /internal/skill-llm (ModelRouter + llm_calls)
  export MOBIUS_SKILL_LLM_INTERNAL_KEY="${MOBIUS_SKILL_LLM_INTERNAL_KEY:-mobius-local-skill-llm-dev}"
  _start "mobius-chat-api" "cd $MOBIUS_ROOT/mobius-chat && MOBIUS_USE_REACT=1 $VENV/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000"
fi

# --- mobius-chat worker (Redis queue; always started) ---
if [[ -d "$MOBIUS_ROOT/mobius-chat" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-skills/web-scraper/.env"
  [[ -f "$MOBIUS_ROOT/mobius-config/.env" ]] && _load_env "$MOBIUS_ROOT/mobius-config/.env"
  _load_env "$MOBIUS_ROOT/mobius-chat/.env"
  export MOBIUS_USE_REACT=1
  export QUEUE_TYPE="${QUEUE_TYPE:-redis}"
  [[ -z "${MCP_SERVER_URL:-}" ]] && [[ -d "$MOBIUS_ROOT/mobius-skills-mcp" ]] && export MCP_SERVER_URL="http://localhost:8006/mcp"
  _wait_redis_for_chat
  _start "mobius-chat-worker" "cd $MOBIUS_ROOT/mobius-chat && MOBIUS_USE_REACT=1 $VENV/bin/python3 -m app.worker"
fi

# --- mobius-rag backend (port 8001) ---
if [[ -d "$MOBIUS_ROOT/mobius-rag" ]]; then
  _kill_port 8001
  _load_env "$MOBIUS_ROOT/mobius-rag/.env"
  _start "mobius-rag-backend" "cd $MOBIUS_ROOT/mobius-rag && $VENV/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload"
fi

# --- mobius-rag chunking worker ---
if [[ -d "$MOBIUS_ROOT/mobius-rag" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-rag/.env"
  _start "mobius-rag-chunking-worker" "cd $MOBIUS_ROOT/mobius-rag && $VENV/bin/python3 -m app.worker"
fi

# --- mobius-rag embedding worker ---
if [[ -f "$MOBIUS_ROOT/mobius-rag/app/embedding_worker.py" ]]; then
  _load_env "$MOBIUS_ROOT/mobius-rag/.env"
  _start "mobius-rag-embedding-worker" "cd $MOBIUS_ROOT/mobius-rag && $VENV/bin/python3 -m app.embedding_worker"
fi

# --- mobius-rag-api (port 8030): POST /retrieve - Mobius or lazy RAG path ---
# Load mobius-config first, mobius-chat last so CHAT_RAG_DATABASE_URL (BM25 corpus) wins.
if [[ -d "$MOBIUS_ROOT/mobius-rag-api" ]]; then
  _kill_port 8030
  [[ -f "$MOBIUS_ROOT/mobius-config/.env" ]] && _load_env "$MOBIUS_ROOT/mobius-config/.env"
  _load_env "$MOBIUS_ROOT/mobius-chat/.env"
  _start "mobius-rag-api" "cd $MOBIUS_ROOT/mobius-rag-api && PYTHONPATH=$MOBIUS_ROOT/mobius-retriever/src $VENV/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8030"
fi

# --- mobius-qa lexicon maintenance API (port 8010) ---
# Serves the Lexicon UI data endpoints used by the static app under /lexicon/.
if [[ -d "$MOBIUS_ROOT/mobius-qa/lexicon-maintenance" ]]; then
  _kill_port 8010
  _load_env "$MOBIUS_ROOT/mobius-qa/lexicon-maintenance/.env"
  _load_env "$MOBIUS_ROOT/mobius-rag/.env"
  _load_env "$MOBIUS_ROOT/mobius-chat/.env"

  # Derive QA/RAG URLs from cloud DATABASE_URL or CHAT_RAG_DATABASE_URL (same host).
  if [[ -z "${QA_DATABASE_URL:-}" ]]; then
    pg_src="${DATABASE_URL:-${CHAT_RAG_DATABASE_URL:-}}"
    pg_user="$(_pg_user_from_url "$pg_src")"
    pg_pass="$(_pg_pass_from_url "$pg_src")"
    pg_host="$(_pg_host_from_url "$pg_src")"
    pg_port="$(_pg_port_from_url "$pg_src")"
    if [[ -n "$pg_user" && -n "$pg_pass" ]]; then
      QA_DATABASE_URL="postgresql://${pg_user}:${pg_pass}@${pg_host}:${pg_port}/mobius_qa?connect_timeout=5"
    fi
  fi
  if [[ -z "${RAG_DATABASE_URL:-}" ]]; then
    pg_src="${DATABASE_URL:-${CHAT_RAG_DATABASE_URL:-}}"
    pg_user="$(_pg_user_from_url "$pg_src")"
    pg_pass="$(_pg_pass_from_url "$pg_src")"
    pg_host="$(_pg_host_from_url "$pg_src")"
    pg_port="$(_pg_port_from_url "$pg_src")"
    if [[ -n "$pg_user" && -n "$pg_pass" ]]; then
      RAG_DATABASE_URL="postgresql://${pg_user}:${pg_pass}@${pg_host}:${pg_port}/mobius_rag?connect_timeout=5"
    fi
  fi

  export QA_DATABASE_URL RAG_DATABASE_URL
  _start "mobius-qa-lexicon-api" "cd $MOBIUS_ROOT/mobius-qa/lexicon-maintenance && $VENV/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8010"
