# product-awareness — Cloud Run dev config.

GCP_PROJECT=mobius-os-dev
GCP_REGION=us-central1

SERVICE_NAME=mobius-product-awareness
SERVICE_ACCOUNT=mobius-platform-dev@mobius-os-dev.iam.gserviceaccount.com
AR_REPO=mobius-product-awareness
IMAGE_BASE=us-central1-docker.pkg.dev/mobius-os-dev/mobius-product-awareness/product-awareness

# pgvector on the shared Cloud SQL (own table product_docs_embeddings on mobius_rag,
# where the vector extension is already enabled). psycopg2 libpq URI over the socket.
CLOUDSQL_INSTANCE=mobius-os-dev:us-central1:mobius-platform-dev-db
PRODUCT_DOCS_DATABASE_URL=postgresql://postgres@/mobius_rag?host=/cloudsql/mobius-os-dev:us-central1:mobius-platform-dev-db
# Password auth (postgres user). Password comes from Secret Manager `db-password`,
# injected as PRODUCT_DOCS_DB_PASSWORD via --set-secrets (not stored here).
PRODUCT_DOCS_DB_NAME=mobius_rag
PRODUCT_DOCS_DB_USER=postgres
PRODUCT_DOCS_DB_HOST=/cloudsql/mobius-os-dev:us-central1:mobius-platform-dev-db
DB_PASSWORD_SECRET=db-password

# Vertex embedder (gemini-embedding-001 @ 1536, pinned) — SA provides ADC.
PRODUCT_DOCS_STORE=pgvector
PRODUCT_DOCS_EMBEDDER=vertex
VERTEX_PROJECT_ID=mobius-os-dev
VERTEX_LOCATION=us-central1

# τ_gap — CALIBRATED 2026-07-02 against live Vertex+pgvector (two-sided probe:
# in-corpus p10=0.602, out-corpus p90=0.486 → clean separation). Midpoint.
PRODUCT_HELP_TAU_GAP=0.544

# Small: single read endpoint, embeds one query per call.
RUN_MEMORY=1Gi
RUN_CPU=1
RUN_CONCURRENCY=40
RUN_TIMEOUT=30
RUN_MIN_INSTANCES=0
RUN_MAX_INSTANCES=3
