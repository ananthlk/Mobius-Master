# Google Custom Search (optional; enables Google when set)
# 1. Enable API: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# 2. Create Programmable Search Engine: https://programmablesearchengine.google.com/controlpanel/create
# 3. Get API key: https://developers.google.com/custom-search/v1/overview (Get a Key)
# GOOGLE_CSE_API_KEY=your-api-key
# GOOGLE_CSE_CX=your-search-engine-id

# Fallback to DuckDuckGo when Google not configured or fails (default: true)
# GOOGLE_SEARCH_USE_DUCKDUCKGO_FALLBACK=true
